{
  "name": "canwin-team-os",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run verify:build-target && vite",
    "build": "npm run verify:build-target && npm run build:app",
    "build:app": "tsc -b && vite build",
    "build:p0-static": "tsc -b && vite build --outDir dist-p0-static --emptyOutDir",
    "build:team-os-4": "npm run build --prefix apps/team-os-4",
    "typecheck:team-os-4-domain": "npm run typecheck --prefix packages/team-os-4-domain",
    "test:team-os-4-migration-tool": "npm run typecheck --prefix tools/migrate-3-to-4 && npm run selftest --prefix tools/migrate-3-to-4",
    "test:team-os-4-foundation": "node platform/team-os-4/supabase/verify-foundation.mjs",
    "test:team-os-4-bootstrap-page-qa": "node scripts/p0/verify-greenfield-bootstrap-page-qa.mjs",
    "test:team-os-4-bootstrap": "npm run selftest --prefix platform/team-os-4/tools/bootstrap",
    "test:team-os-4-g1-runner": "node scripts/p1/verify-team-os-4-g1-runner.mjs",
    "test:team-os-4-g2-contract": "node scripts/p2/verify-team-os-4-g2-contract.mjs",
    "test:team-os-4-g2-local": "node scripts/p2/run-team-os-4-g2-local-gates.mjs",
    "test:team-os-4-acceptance-accounts": "npm run selftest --prefix platform/team-os-4/tools/acceptance-accounts",
    "test:p0:greenfield-root": "node scripts/p0/verify-greenfield-root-contract.mjs",
    "test:lead-parser": "node --experimental-strip-types scripts/test-lead-paste-parser.ts",
    "test:crm-ui": "node --experimental-strip-types scripts/test-crm-command-center-ui.ts",
    "test:p0:migrations": "node scripts/p0/verify-migration-manifest.mjs",
    "test:p0:project-ref": "node scripts/p0/verify-project-ref-contract.mjs",
    "test:p0:core-business": "node scripts/p0/verify-core-business-contract.mjs",
    "test:p0:role-migration": "node scripts/p0/verify-role-migration-contract.mjs",
    "test:p0:live-table-evidence": "node scripts/p0/verify-public-table-live-evidence.mjs",
    "test:p0:live-routine-evidence": "node scripts/p0/verify-public-routine-live-evidence.mjs",
    "test:p0:routine-callers": "node scripts/p0/verify-routine-caller-crosscheck.mjs",
    "test:p0:advisor-risk": "node scripts/p0/verify-advisor-risk-priority-evidence.mjs",
    "capture:p0:classification-evidence": "node scripts/p0/capture-object-classification-evidence.mjs",
    "build:p0:classification-freeze": "node scripts/p0/build-object-classification-freeze.mjs",
    "test:p0:classification-freeze": "node scripts/p0/verify-object-classification-freeze.mjs",
    "test:p0:build-target": "node scripts/p0/verify-build-target.mjs --self-test",
    "test:p0:backup-contract": "node scripts/p0/verify-backup-manifest-contract.mjs",
    "verify:p0:backup-package": "node scripts/p0/verify-backup-package-runtime.mjs",
    "audit:p0:recovery-toolchain": "node scripts/p0/audit-recovery-toolchain.mjs",
    "test:p0:sealed-recovery-runtime": "node scripts/p0/test-sealed-recovery-runtime.mjs --skip-local-postgres",
    "preflight:p0:sealed-recovery": "node scripts/p0/preflight-sealed-recovery.mjs",
    "backup:p0:sealed-recovery": "node scripts/p0/create-sealed-backup.mjs",
    "restore:p0:sealed-recovery": "node scripts/p0/restore-sealed-backup.mjs",
    "test:p0:restore-run": "node scripts/p0/verify-restore-run-contract.mjs",
    "test:p0:sealed-recovery-contract": "node scripts/p0/verify-sealed-recovery-contract.mjs",
    "test:p0:ci-database-contract": "node scripts/p0/verify-ci-database-contract.mjs",
    "test:p0:ci-database-runner": "node scripts/p0/run-ci-database-gates.mjs --self-test",
    "test:p0:ci-database": "node scripts/p0/run-ci-database-gates.mjs",
    "test:p0:static": "node scripts/p0/run-static-gates.mjs",
    "test:p0:static:legacy": "node scripts/p0/run-static-gates.mjs --legacy",
    "test:p0:local": "node scripts/p0/run-local-integration.mjs",
    "test:p0:local:legacy": "node scripts/p0/run-local-integration.mjs --legacy",
    "test:p1:app-shell": "node scripts/p1/verify-app-shell.mjs",
    "test:p1:isolated-runner": "node scripts/p1/run-isolated-runtime.mjs --self-test",
    "test:p1:isolated-runner-contract": "node scripts/p1/verify-isolated-runtime-runner.mjs",
    "test:p1:postgres-selftest": "node scripts/p1/verify-pending-trigger-postgres.mjs --self-test",
    "test:p1:page-precheck": "node scripts/p1/precheck-page-acceptance.mjs",
    "test:p1:real-account-selftest": "node scripts/p1/manage-real-page-accounts.mjs --self-test",
    "test:p1:real-page-selftest": "node scripts/p1/run-real-page-acceptance.mjs --self-test",
    "test:p1:access-admin-v1": "node --experimental-strip-types scripts/p1/verify-access-admin-v1-write-chain.ts",
    "verify:build-target": "node scripts/p0/verify-build-target.mjs",
    "verify:build-artifact": "node scripts/p0/verify-build-target.mjs --artifact dist",
    "verify:build-artifact:static": "node scripts/p0/verify-build-target.mjs --artifact-compile-only dist-p0-static",
    "lint": "eslint .",
    "preview": "npm run verify:build-target && npm run verify:build-artifact && vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@supabase/supabase-js": "^2.108.2",
    "chart.js": "^4.5.1",
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "read-excel-file": "^5.8.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.61.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
